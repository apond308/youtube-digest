# YouTube Digest - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- LLM API (OpenAI-compatible) ----
# Any OpenAI-compatible API works (OpenAI, Anthropic via proxy, local LLM, etc.)
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="gpt-4o-mini"

# ---- Gmail SMTP ----
# Used to send digest emails. Requires a Gmail App Password:
# https://support.google.com/accounts/answer/185833
GMAIL_ADDRESS="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ---- Processing ----
# Max videos per subscriber per daily run (0 = no global limit, per-subscriber config takes precedence)
MAX_VIDEOS_PER_DAY=5
